{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "global": {
            "description": "Global values shared between all subcharts",
            "$comment": "Added automatically by 'helm schema' to allow this chart to be used as a Helm dependency, as the `additionalProperties` setting would otherwise collide with Helm's special 'global' values key.",
            "type": [
                "object",
                "null"
            ]
        },
        "kagent": {
            "type": "object",
            "properties": {
                "controller": {
                    "type": "object",
                    "properties": {
                        "agentImage": {
                            "type": "object",
                            "properties": {
                                "repository": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": true
                        },
                        "image": {
                            "type": "object",
                            "properties": {
                                "repository": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": true
                        },
                        "skillsInitImage": {
                            "type": "object",
                            "properties": {
                                "repository": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": true
                },
                "fullnameOverride": {
                    "type": "string"
                },
                "kagent-tools": {
                    "type": "object",
                    "properties": {
                        "tools": {
                            "type": "object",
                            "properties": {
                                "image": {
                                    "type": "object",
                                    "properties": {
                                        "registry": {
                                            "type": "string"
                                        },
                                        "repository": {
                                            "type": "string"
                                        }
                                    },
                                    "additionalProperties": true
                                },
                                "resources": {
                                    "type": "object",
                                    "properties": {
                                        "limits": {
                                            "type": "object",
                                            "properties": {
                                                "cpu": {
                                                    "type": "string"
                                                },
                                                "ephemeral-storage": {
                                                    "type": "string"
                                                },
                                                "memory": {
                                                    "type": "string"
                                                }
                                            },
                                            "additionalProperties": false
                                        },
                                        "requests": {
                                            "type": "object",
                                            "properties": {
                                                "cpu": {
                                                    "type": "string"
                                                },
                                                "ephemeral-storage": {
                                                    "type": "string"
                                                },
                                                "memory": {
                                                    "type": "string"
                                                }
                                            },
                                            "additionalProperties": false
                                        }
                                    },
                                    "additionalProperties": true
                                }
                            },
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": true
                },
                "namespaceOverride": {
                    "type": "string"
                },
                "registry": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                },
                "ui": {
                    "type": "object",
                    "properties": {
                        "image": {
                            "type": "object",
                            "properties": {
                                "repository": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": true
                }
            },
            "additionalProperties": true
        }
    },
    "additionalProperties": false
}
